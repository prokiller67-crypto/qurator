# Qurator backend configuration (all optional — sensible defaults are baked in).
QURATOR_PG_HOST=localhost
QURATOR_PG_PORT=5433
QURATOR_PG_USER=qurator
QURATOR_PG_PASSWORD=qurator
QURATOR_PG_DB=qurator

# Demo dataset scale + tuned storage budget.
QURATOR_SEED_TRANSACTIONS=2000000
QURATOR_SEED_RNG=42
QURATOR_BUDGET_MB=250
